# Uchicode local environment template.
# Copy to .env or .env.production and replace placeholders locally.
# Never commit real secrets or production values.

DJANGO_DEBUG=<true-or-false>
DJANGO_SECRET_KEY=<generate-a-new-secret>
DJANGO_ALLOWED_HOSTS=<comma-separated-hosts>
DJANGO_CSRF_TRUSTED_ORIGINS=<comma-separated-origins>
DJANGO_CORS_ALLOWED_ORIGINS=<comma-separated-origins>
DJANGO_CORS_ALLOW_CREDENTIALS=<true-or-false>

DATABASE_URL=<database-url>
POSTGRES_DB=<database-name>
POSTGRES_USER=<database-user>
POSTGRES_PASSWORD=<database-password>
REDIS_URL=<redis-url>

VITE_API_BASE_URL=<frontend-api-base-url>

QWEN_API_KEY=<provider-api-key>
QWEN_BASE_URL=<provider-base-url>
QWEN_MODEL=<provider-model>
QWEN_TIMEOUT_SECONDS=<timeout-seconds>
AI_DAILY_REQUEST_LIMIT=<per-user-daily-limit>
AI_GLOBAL_DAILY_REQUEST_LIMIT=<global-daily-limit>

SMS_PROVIDER=<provider-name-or-disabled>
SMS_API_KEY=<sms-api-key>
SMS_LOGIN=<sms-login>
SMS_PASSWORD=<sms-password>
SMS_FROM=<sms-sender>
SMS_TIMEOUT_SECONDS=<timeout-seconds>

DJANGO_SECURE_SSL=<true-or-false>
DJANGO_SECURE_SSL_REDIRECT=<true-or-false>
DJANGO_SESSION_COOKIE_SECURE=<true-or-false>
DJANGO_CSRF_COOKIE_SECURE=<true-or-false>
DJANGO_CSRF_COOKIE_HTTPONLY=<true-or-false>
AUTH_REFRESH_COOKIE_NAME=<cookie-name>
AUTH_REFRESH_COOKIE_PATH=<cookie-path>
AUTH_REFRESH_COOKIE_DOMAIN=<cookie-domain-or-empty>
AUTH_REFRESH_COOKIE_SECURE=<true-or-false>
AUTH_REFRESH_COOKIE_SAMESITE=<lax-strict-or-none>
DJANGO_SECURE_HSTS_SECONDS=<seconds>
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=<true-or-false>
DJANGO_SECURE_HSTS_PRELOAD=<true-or-false>
